{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "observability": {
      "type": "object",
      "properties": {
        "traces": { "$ref": "#/definitions/toggle" },
        "metrics": { "$ref": "#/definitions/toggle" },
        "spanEvents": { "$ref": "#/definitions/toggle" },
        "otlp": {
          "type": "object",
          "properties": {
            "endpoint": { "type": "string" },
            "protocol": { "enum": ["http/protobuf", "grpc"] },
            "insecure": { "type": "boolean" },
            "existingSecret": { "type": "string" },
            "headersKey": { "type": "string", "minLength": 1 }
          }
        },
        "metricExportIntervalMillis": { "type": "integer", "minimum": 1000 },
        "resourceAttributes": { "type": "object", "additionalProperties": { "type": "string", "maxLength": 256 } }
      }
    },
    "litellm": {
      "type": "object",
      "properties": {
        "rolePolicies": {
          "type": "object",
          "required": ["planner", "developer", "reviewer"],
          "properties": {
            "planner": { "$ref": "#/definitions/rolePolicy" },
            "developer": { "$ref": "#/definitions/rolePolicy" },
            "reviewer": { "$ref": "#/definitions/rolePolicy" }
          }
        }
      }
    }
  },
  "definitions": {
    "toggle": {
      "type": "object",
      "properties": { "enabled": { "type": "boolean" } },
      "required": ["enabled"]
    },
    "rolePolicy": {
      "type": "object",
      "required": ["model", "maxBudgetUsd", "budgetDuration", "toolset", "existingSecret", "apiKeyKey"],
      "properties": {
        "model": { "type": "string", "minLength": 1 },
        "maxBudgetUsd": { "type": "number", "exclusiveMinimum": 0 },
        "budgetDuration": { "type": "string", "minLength": 1 },
        "toolset": { "type": "string", "minLength": 1 },
        "existingSecret": { "type": "string", "minLength": 1 },
        "apiKeyKey": { "type": "string", "minLength": 1 }
      }
    }
  }
}
